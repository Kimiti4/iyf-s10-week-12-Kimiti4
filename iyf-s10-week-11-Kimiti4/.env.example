# Server
NODE_ENV=production
PORT=3000

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# JWT
JWT_SECRET=your-secret-key-min-32-characters-random
JWT_EXPIRES_IN=7d

# Frontend URLs (for CORS) - comma-separated
FRONTEND_URL=https://jamii-link-ke.vercel.app

# Logging
LOG_LEVEL=info
