# Backend Environment Variables
# ⚠️ IMPORTANT: Copy this to .env and fill in your actual values
# NEVER commit .env files with real credentials!

# Server Configuration
PORT=3001
NODE_ENV=production
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# Database Configuration
# Set this in Railway Dashboard for production!
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/jamiilink_db

# JWT Authentication
# Generate secure secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Set this in Railway Dashboard for production!
JWT_SECRET=your_secure_random_secret_here
JWT_EXPIRES_IN=7d

# Demo Token (for frontend testing)
DEMO_TOKEN=jamii-demo-2026

# Tiannara Core Integration (AI Moderation Service)
TIANNARA_API_URL=http://localhost:8000
